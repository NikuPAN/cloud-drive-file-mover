# ------------------------------------------------------------------------------
# Cloud Drive File Mover — env template
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ------------------------------------------------------------------------------

# Public origin used for OAuth redirect URIs.
# Must match exactly what is registered in each provider's developer console.
PUBLIC_ORIGIN=http://localhost:5173

# --- Google OAuth (Google Cloud Console → APIs & Services → Credentials) ---
# Redirect URI to register: ${PUBLIC_ORIGIN}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Microsoft OAuth (Azure Portal → App registrations) ---
# Redirect URI to register: ${PUBLIC_ORIGIN}/api/auth/microsoft/callback
# Supported account types: "Accounts in any organizational directory and personal Microsoft accounts"
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Usually "common" for multi-tenant + personal MS accounts
MICROSOFT_TENANT=common

# --- Dropbox OAuth (dropbox.com/developers/apps) ---
# Create app: Scoped access → Full Dropbox
# Redirect URI to register: ${PUBLIC_ORIGIN}/api/auth/dropbox/callback
# Permissions required: files.metadata.read, files.content.read, files.content.write, account_info.read
DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=

# --- Box OAuth (developer.box.com → My Apps → Create New App) ---
# App type: Custom App → User Authentication (OAuth 2.0)
# Redirect URI to register: ${PUBLIC_ORIGIN}/api/auth/box/callback
BOX_CLIENT_ID=
BOX_CLIENT_SECRET=

# --- Session cookie encryption ---
# 32-byte random key, base64url-encoded. Generate with:
#   node -e "console.log(crypto.randomBytes(32).toString('base64url'))"
SESSION_SECRET=

# --- Donate page (optional) ---
# Create a PayPal Donate button at paypal.com/buttons, then paste the hosted_button_id here.
# Leave blank to show a "coming soon" placeholder on the donate page.
PUBLIC_PAYPAL_BUTTON_ID=
